# GatiSetu Backend Environment Variables
# Copy this file to .env and fill in your API keys

# OpenRouter API Key (free tier) — get from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# Google Gemini API Key (fallback) — get from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here
